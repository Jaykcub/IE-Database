# Neon — pooled connection for the app (Vercel / serverless-friendly).
# In Neon dashboard: use the connection string that includes "-pooler" or "pooler" host when offered.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Neon — direct (non-pooled) connection for Prisma Migrate.
# Use the primary branch connection string without the pooler suffix, or Neon's explicit "direct" URL.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Session signing for Admin login (use a long random string in production).
HULLBOARD_SESSION_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
